---
const pathname = Astro.url.pathname;
const isHome = pathname === "/";

const navLinks = [
  { href: "/familia", label: "Família" },
  { href: "/drinks", label: "Drinks" },
  { href: "/sobre", label: "Sobre Nós" },
  { href: "/historias", label: "Histórias" },
];
---

<header
  id="topbar"
  class:list={[
    "fixed top-0 left-0 right-0 z-100 flex items-center justify-between px-15 py-7 transition-all duration-400",
    !isHome && "scrolled",
  ]}
  style="background: linear-gradient(180deg, rgba(10,6,4,0.85) 0%, rgba(10,6,4,0) 100%); backdrop-filter: blur(8px);"
>
  <a
    href="/"
    class="flex items-center no-underline text-gold-light"
    aria-label="BLACKMOOR — Ir para a home"
  >
    <span class="grid place-items-center w-16 h-16">
      <img
        src="/img/brand-mark.png"
        alt="BLACKMOOR"
        width="64"
        height="64"
        class="brand-img w-full h-full object-contain"
      />
    </span>
  </a>

  <nav class="hidden lg:block">
    <ul class="flex gap-12 list-none m-0 p-0">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "nav-link relative py-1.5 px-0 font-display text-[13px] tracking-[4px] uppercase no-underline transition-colors duration-300",
                pathname === link.href ? "text-gold-light active" : "text-cream",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="flex items-center gap-6">
    <button
      class="icon-btn bg-transparent w-10 h-10 rounded-full grid place-items-center text-cream cursor-pointer transition-all duration-300"
      style="border: 1px solid rgba(212,169,73,0.3);"
      aria-label="Busca"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
    </button>
    <button
      class="icon-btn bg-transparent w-10 h-10 rounded-full grid place-items-center text-cream cursor-pointer transition-all duration-300"
      style="border: 1px solid rgba(212,169,73,0.3);"
      aria-label="Favoritos"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"
        ></path>
      </svg>
    </button>
    <a
      href="/cadastro"
      class="icon-btn bg-transparent w-10 h-10 rounded-full grid place-items-center text-cream no-underline transition-all duration-300"
      style="border: 1px solid rgba(212,169,73,0.3);"
      aria-label="Criar conta"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="8" r="4"></circle>
        <path d="M5.5 21a6.5 6.5 0 0 1 13 0"></path>
      </svg>
    </a>
  </div>
</header>

<style>
  #topbar.scrolled {
    padding-top: 16px;
    padding-bottom: 16px;
    background: rgba(10, 6, 4, 0.95) !important;
    border-bottom: 1px solid rgba(212, 169, 73, 0.15);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: all 0.4s ease;
    transform: translateX(-50%);
  }
  .nav-link:hover {
    color: var(--color-gold-light);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .nav-link.active {
    color: var(--color-gold-light);
  }

  .icon-btn:hover {
    border-color: var(--color-gold) !important;
    background: rgba(212, 169, 73, 0.1) !important;
    color: var(--color-gold-light);
  }

</style>
