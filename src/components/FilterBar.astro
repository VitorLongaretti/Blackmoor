---
const filters = [
  { label: "ESTILOS", value: "Todos estilos" },
  { label: "PALADARES", value: "Todos paladares" },
  { label: "OCASIÕES", value: "Todas ocasiões" },
  { label: "NÍVEIS DE HABILIDADE", value: "Todos níveis" },
];
---

<div
  class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 max-w-[1300px] mx-auto mb-15"
>
  {
    filters.map((f) => (
      <div
        class="filter flex justify-between items-center px-6 py-[18px] text-cream font-display text-[12px] tracking-[3px] cursor-pointer transition-all duration-300"
        style="background: rgba(74,20,24,0.15); border: 1px solid rgba(212,169,73,0.25);"
      >
        <span class="flex flex-col gap-1">
          <span class="text-[9px] text-gold/70 tracking-[2px]">{f.label}</span>
          <span class="text-cream text-[13px]">{f.value}</span>
        </span>
        <span class="text-gold text-[10px]">⌄</span>
      </div>
    ))
  }
</div>

<style>
  .filter:hover {
    border-color: var(--color-gold) !important;
    background: rgba(212, 169, 73, 0.08) !important;
  }
</style>
