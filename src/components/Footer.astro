---
const quickLinks = [
  { href: "#", label: "Entre em contato" },
  { href: "#", label: "Informações dos produtos" },
  { href: "#", label: "Perguntas frequentes" },
  { href: "#", label: "Whiskipedia" },
];

const legalLinks = [
  { href: "#", label: "Responsabilidade social" },
  { href: "#", label: "Política de cookies" },
  { href: "#", label: "Política de privacidade" },
  { href: "#", label: "Termos e condições" },
  { href: "#", label: "Declaração de acessibilidade" },
  { href: "#", label: "Gerenciar cookies" },
];
---

<footer
  class="bg-black"
  style="border-top: 1px solid rgba(212,169,73,0.15);"
>
  <div class="max-w-[1300px] mx-auto px-15">
    <div
      class="newsletter flex flex-col lg:flex-row lg:items-center justify-between gap-8 py-16"
      style="border-bottom: 1px solid rgba(212,169,73,0.10);"
    >
      <h3
        class="newsletter-title font-display tracking-[3px] text-cream"
        style="font-size: clamp(20px, 2vw, 30px);"
      >
        <span class="newsletter-script">Inscreva-se para</span> RECEBER NOVIDADES BLACKMOOR
      </h3>
      <a
        href="#"
        class="newsletter-cta inline-flex items-center justify-center bg-cream text-black px-10 py-4 font-display text-[13px] tracking-[3px] uppercase no-underline transition-colors duration-300 whitespace-nowrap"
      >
        Inscreva-se
      </a>
    </div>

    <div
      class="brand-row grid grid-cols-1 md:grid-cols-3 items-center gap-8 py-12"
    >
      <div class="flex items-center gap-2 text-cream/80 text-[14px] md:justify-start justify-center">
        <span class="text-[18px]">🇧🇷</span>
        <span>Brasil</span>
      </div>

      <a
        href="/"
        class="brand-lockup flex justify-center items-center gap-3 no-underline"
        aria-label="BLACKMOOR — Ir para a home"
      >
        <img
          src="/img/brand-mark.png"
          alt=""
          width="40"
          height="40"
          class="object-contain"
        />
        <span class="font-display text-[17px] tracking-[6px] text-gold-light">
          BLACKMOOR
        </span>
      </a>

      <div class="flex items-center gap-5 md:justify-end justify-center">
        <a href="#" aria-label="Facebook" class="social-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"
            ></path>
          </svg>
        </a>
        <a href="#" aria-label="X" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
        <a href="#" aria-label="Instagram" class="social-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="2" y="2" width="20" height="20" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="18" cy="6" r="1.2" fill="currentColor"></circle>
          </svg>
        </a>
        <a href="#" aria-label="YouTube" class="social-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <nav aria-label="Links rápidos" class="pb-6">
      <ul
        class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-cream/85 text-[14px]"
      >
        {
          quickLinks.map((l) => (
            <li>
              <a href={l.href} class="quick-link no-underline">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav
      aria-label="Links legais"
      class="py-5"
      style="border-top: 1px solid rgba(212,169,73,0.10);"
    >
      <ul
        class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-cream/55 text-[12px] tracking-[0.5px]"
      >
        {
          legalLinks.map((l) => (
            <li>
              <a href={l.href} class="legal-link no-underline">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="pt-6 pb-10 text-cream/40 text-[12px] leading-relaxed space-y-1">
      <p>© 2026 BLACKMOOR DISTILLERY — TODOS OS DIREITOS RESERVADOS</p>
      <p>O consumo excessivo de álcool causa riscos à saúde. Beba com moderação.</p>
      <p>Compartilhe o conteúdo apenas com pessoas com idade legal para beber.</p>
    </div>
  </div>
</footer>

<style>
  .newsletter-script {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    font-size: 1.25em;
  }

  .newsletter-cta:hover {
    background: var(--color-gold-light);
  }

  .brand-lockup:hover span {
    color: var(--color-gold);
  }

  .social-icon {
    color: var(--color-cream);
    opacity: 0.7;
    transition: all 0.3s ease;
    display: inline-flex;
  }
  .social-icon:hover {
    color: var(--color-gold-light);
    opacity: 1;
    transform: translateY(-2px);
  }

  .quick-link {
    color: inherit;
    transition: color 0.3s ease;
  }
  .quick-link:hover {
    color: var(--color-gold-light);
  }

  .legal-link {
    color: inherit;
    transition: color 0.3s ease;
  }
  .legal-link:hover {
    color: var(--color-cream);
  }
</style>
