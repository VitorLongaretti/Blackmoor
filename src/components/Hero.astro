---
---

<section
  class="hero-section relative min-h-screen flex flex-col items-center justify-between overflow-hidden text-center"
  style="padding-top: 15vh; padding-bottom: 6vh;"
>
  <div class="hero-overlay absolute inset-0 pointer-events-none z-[2]"></div>

  <span class="side-text left hidden md:block">EST · 1876</span>
  <span class="side-text right hidden md:block">BLENDED · SCOTCH</span>

  <h1 class="sr-only">BLACKMOOR</h1>

  <div
    class="font-display text-[12px] tracking-[12px] text-gold uppercase px-10 z-[5] fade-up"
    style="animation-delay: 0.3s;"
  >
    SCOTCH WHISKY · HIGHLANDS
  </div>

  <a
    href="/familia"
    class="scroll-prompt z-[5] text-center no-underline fade-up"
    style="animation-delay: 1s;"
  >
    <span
      class="block font-display text-[10px] tracking-[6px] text-gold mb-3 transition-colors"
      >SCROLL PARA VER A FAMÍLIA</span
    >
    <div
      class="scroll-line w-px h-[50px] mx-auto relative overflow-hidden"
      style="background: linear-gradient(180deg, var(--color-gold), transparent);"
    ></div>
  </a>
</section>

<style>
  .hero-section {
    background: url("/img/bottle-hero.png") center center / cover no-repeat;
  }

  .hero-overlay {
    background:
      radial-gradient(
        ellipse at center,
        rgba(10, 6, 4, 0) 35%,
        rgba(10, 6, 4, 0.4) 100%
      ),
      linear-gradient(
        180deg,
        rgba(10, 6, 4, 0.72) 0%,
        rgba(10, 6, 4, 0.1) 26%,
        rgba(10, 6, 4, 0.12) 56%,
        rgba(10, 6, 4, 0.9) 100%
      );
  }

  .side-text {
    position: absolute;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: left center;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 6px;
    color: var(--color-gold);
    opacity: 0.5;
    z-index: 5;
  }
  .side-text.left {
    left: 40px;
  }
  .side-text.right {
    right: 40px;
    transform-origin: right center;
    transform: translateY(-50%) rotate(90deg);
  }

  .scroll-prompt:hover span {
    color: var(--color-gold-light);
  }

  .scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    width: 100%;
    height: 20px;
    background: var(--color-gold-light);
    animation: scrollDown 2s ease-in-out infinite;
  }
</style>
