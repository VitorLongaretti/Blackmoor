---
interface Props {
  name: string;
  difficulty: string;
  time: string;
}

const { name, difficulty, time } = Astro.props;
---

<div
  class="drink-card relative overflow-hidden cursor-pointer transition-all duration-400"
  style="aspect-ratio: 4/5; background: radial-gradient(circle at 30% 40%, rgba(184,115,51,0.3), transparent 60%), linear-gradient(180deg, #2c0a0d, #1a0f08); border: 1px solid rgba(212,169,73,0.15);"
>
  <div class="absolute bottom-6 left-6 right-6 z-[2]">
    <span
      class="inline-block font-display text-[10px] tracking-[3px] text-gold px-3 py-1 mb-3"
      style="border: 1px solid var(--color-gold);"
    >
      {difficulty}
    </span>
    <h3 class="font-display text-[20px] text-gold-light tracking-[3px] mb-1.5">
      {name}
    </h3>
    <p class="italic text-cream/70 text-[14px]">{time}</p>
  </div>
</div>

<style>
  .drink-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.9));
    pointer-events: none;
  }
  .drink-card:hover {
    border-color: var(--color-gold) !important;
    transform: translateY(-6px);
  }
</style>
