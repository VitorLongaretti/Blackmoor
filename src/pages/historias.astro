---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Histórias · BLACKMOOR">
  <main class="pt-32 min-h-screen bg-black">
    <section class="relative py-30 px-15 max-w-5xl mx-auto text-center">
      <h1
        class="font-display gold-gradient-text mb-6 tracking-[8px]"
        style="font-size: clamp(40px, 6vw, 80px);"
      >
        HISTÓRIAS
      </h1>
      <p class="italic text-[18px] text-cream/80 mb-10 max-w-2xl mx-auto">
        Crônicas das terras altas, contos de barris e mestres maltadores.
      </p>
      <p class="text-cream/60 text-[15px] tracking-[1px]">
        Em breve — a coleção de histórias BLACKMOOR.
      </p>
    </section>
  </main>
</Layout>
