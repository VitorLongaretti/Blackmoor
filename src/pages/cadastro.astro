---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Criar Conta · BLACKMOOR">
  <main
    class="cadastro-page relative min-h-screen flex items-center justify-center px-6 pt-32 pb-16"
  >
    <div
      class="absolute inset-0 pointer-events-none flex items-center justify-center overflow-hidden"
    >
      <img
        src="/img/brand-mark.png"
        alt=""
        aria-hidden="true"
        class="watermark"
      />
    </div>

    <div class="card relative w-full max-w-[580px]">
      <div class="text-center mb-10">
        <img
          src="/img/brand-mark.png"
          alt=""
          aria-hidden="true"
          class="mx-auto w-14 h-14 mb-5"
        />
        <p
          class="font-display text-[10px] tracking-[8px] text-gold uppercase mb-3"
        >
          Junte-se à Destilaria
        </p>
        <h1
          class="title font-display tracking-[3px] mb-3"
          style="font-size: clamp(34px, 4.5vw, 52px);"
        >
          <span class="title-script">Bem</span>-VINDO
        </h1>
        <p
          class="font-body italic text-cream/70 text-[15px] leading-relaxed max-w-md mx-auto"
        >
          Crie sua conta para acessar lançamentos exclusivos, histórias e
          convites privados das Highlands.
        </p>
      </div>

      <form class="form-stack" novalidate>
        <div class="floating-input">
          <input
            type="email"
            id="email"
            name="email"
            placeholder=" "
            required
            autocomplete="email"
          />
          <label for="email">Endereço de e-mail</label>
        </div>

        <div class="floating-input has-toggle">
          <input
            type="password"
            id="password"
            name="password"
            placeholder=" "
            required
            minlength="8"
            autocomplete="new-password"
          />
          <label for="password">Senha</label>
          <button
            type="button"
            class="toggle-password"
            aria-label="Mostrar senha"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="eye-open"
            >
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="eye-closed hidden"
            >
              <path
                d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"
              ></path>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="floating-input">
            <input
              type="text"
              id="firstname"
              name="firstname"
              placeholder=" "
              required
              autocomplete="given-name"
            />
            <label for="firstname">Primeiro nome</label>
          </div>
          <div class="floating-input">
            <input
              type="text"
              id="lastname"
              name="lastname"
              placeholder=" "
              required
              autocomplete="family-name"
            />
            <label for="lastname">Último nome</label>
          </div>
        </div>

        <div class="floating-input always-float">
          <input
            type="date"
            id="birth"
            name="birth"
            required
            autocomplete="bday"
          />
          <label for="birth">Data de nascimento</label>
        </div>

        <div class="floating-input always-float">
          <select id="country" name="country" required>
            <option value="BR">Brasil</option>
            <option value="PT">Portugal</option>
            <option value="UK">Reino Unido</option>
            <option value="US">Estados Unidos</option>
            <option value="ES">Espanha</option>
            <option value="FR">França</option>
            <option value="DE">Alemanha</option>
            <option value="IT">Itália</option>
          </select>
          <label for="country">País</label>
          <svg
            class="select-chevron"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>

        <label class="checkbox-label">
          <input type="checkbox" required />
          <span class="custom-check"></span>
          <span class="text">
            Reconheço e concordo com as
            <a href="#" class="link">condições de uso</a> e a
            <a href="#" class="link">política de privacidade e cookies</a>.
          </span>
        </label>

        <label class="checkbox-label">
          <input type="checkbox" />
          <span class="custom-check"></span>
          <span class="text">
            Quero receber novidades, lançamentos e convites exclusivos por
            e-mail.
          </span>
        </label>

        <button type="submit" class="submit-btn">
          <span>Criar Conta</span>
          <svg
            width="20"
            height="10"
            viewBox="0 0 20 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="submit-arrow"
          >
            <path d="M0 5h18M14 1l4 4-4 4"></path>
          </svg>
        </button>

        <p class="text-center text-cream/60 text-[14px] mt-2">
          Já tem conta? <a href="#" class="link">Entre</a>
        </p>
      </form>
    </div>
  </main>
</Layout>

<style>
  .cadastro-page {
    background:
      radial-gradient(
        ellipse at 50% 0%,
        rgba(212, 169, 73, 0.1) 0%,
        transparent 55%
      ),
      radial-gradient(
        ellipse at 50% 100%,
        rgba(74, 20, 24, 0.18) 0%,
        transparent 55%
      ),
      var(--color-black);
  }

  .watermark {
    width: 70vw;
    max-width: 900px;
    opacity: 0.035;
  }

  .card {
    background: linear-gradient(180deg, rgba(26, 15, 8, 0.7), rgba(10, 6, 4, 0.85));
    border: 1px solid rgba(212, 169, 73, 0.18);
    padding: clamp(2rem, 5vw, 3.5rem);
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(212, 169, 73, 0.06);
    backdrop-filter: blur(8px);
  }

  .title {
    background: linear-gradient(180deg, var(--color-cream), #c8b58a);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-weight: 600;
  }

  .title-script {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    font-size: 1.3em;
  }

  .form-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .floating-input {
    position: relative;
  }

  .floating-input input,
  .floating-input select {
    width: 100%;
    background: transparent;
    border: 1px solid rgba(212, 169, 73, 0.25);
    padding: 1.5rem 1rem 0.65rem;
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 16px;
    letter-spacing: 0.3px;
    outline: none;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    -webkit-appearance: none;
    appearance: none;
    border-radius: 0;
  }

  .floating-input input::placeholder {
    color: transparent;
  }

  .floating-input.has-toggle input {
    padding-right: 3rem;
  }

  .floating-input label {
    position: absolute;
    left: 1rem;
    top: 1.1rem;
    color: rgba(232, 217, 181, 0.5);
    font-family: var(--font-body);
    font-size: 15px;
    pointer-events: none;
    transition: all 0.25s ease;
    letter-spacing: 0.3px;
  }

  .floating-input input:focus,
  .floating-input select:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 1px rgba(212, 169, 73, 0.25);
  }

  .floating-input input:focus + label,
  .floating-input input:not(:placeholder-shown) + label,
  .floating-input.always-float label {
    top: 0.35rem;
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--color-gold);
    font-family: var(--font-display);
    font-weight: 500;
  }

  .floating-input input[type="date"] {
    color-scheme: dark;
  }

  .floating-input select {
    cursor: pointer;
    padding-right: 2.5rem;
  }

  .select-chevron {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-gold);
    pointer-events: none;
  }

  .toggle-password {
    position: absolute;
    right: 0.8rem;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: rgba(232, 217, 181, 0.55);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    transition: color 0.2s ease;
  }

  .toggle-password:hover {
    color: var(--color-gold-light);
  }

  .hidden {
    display: none;
  }

  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: rgba(232, 217, 181, 0.8);
    user-select: none;
  }

  .checkbox-label input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .custom-check {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border: 1px solid rgba(212, 169, 73, 0.45);
    position: relative;
    transition: all 0.2s ease;
    margin-top: 2px;
    background: transparent;
  }

  .checkbox-label:hover .custom-check {
    border-color: var(--color-gold);
  }

  .checkbox-label input:checked + .custom-check {
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  .checkbox-label input:checked + .custom-check::after {
    content: "";
    position: absolute;
    left: 5px;
    top: 1px;
    width: 5px;
    height: 10px;
    border: solid var(--color-black);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .checkbox-label input:focus-visible + .custom-check {
    box-shadow: 0 0 0 2px rgba(212, 169, 73, 0.35);
  }

  .link {
    color: var(--color-gold-light);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .link:hover {
    color: var(--color-gold);
  }

  .submit-btn {
    position: relative;
    width: 100%;
    padding: 1.15rem 2rem;
    background: linear-gradient(
      135deg,
      var(--color-gold-light),
      var(--color-gold),
      var(--color-gold-deep)
    );
    color: var(--color-black);
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 5px;
    text-transform: uppercase;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.4s ease;
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }

  .submit-btn:hover {
    background: linear-gradient(
      135deg,
      var(--color-gold-light),
      var(--color-gold-light)
    );
    box-shadow:
      0 14px 36px rgba(212, 169, 73, 0.28),
      0 0 0 1px rgba(212, 169, 73, 0.4);
    transform: translateY(-2px);
  }

  .submit-arrow {
    transition: transform 0.3s ease;
  }
  .submit-btn:hover .submit-arrow {
    transform: translateX(6px);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".toggle-password").forEach((btn) => {
    btn.addEventListener("click", () => {
      const input = btn.parentElement?.querySelector<HTMLInputElement>("input");
      const eyeOpen = btn.querySelector<SVGElement>(".eye-open");
      const eyeClosed = btn.querySelector<SVGElement>(".eye-closed");
      if (!input || !eyeOpen || !eyeClosed) return;

      const isPassword = input.type === "password";
      input.type = isPassword ? "text" : "password";
      eyeOpen.classList.toggle("hidden", isPassword);
      eyeClosed.classList.toggle("hidden", !isPassword);
      btn.setAttribute(
        "aria-label",
        isPassword ? "Esconder senha" : "Mostrar senha"
      );
    });
  });
</script>
